# COVID Tracker Environment Variables
# Copy this file to .env and fill in the values

# Server Port (required)
PORT=5173

# Base path for deployment (required)
# Use "/" for root domain, "/covid-tracker" for subdirectory
BASE_PATH=/

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=3

# Cache Configuration (in minutes)
VITE_CACHE_TIME=5
VITE_STALE_TIME=2

# Feature Flags
VITE_ENABLE_ANALYTICS=false
